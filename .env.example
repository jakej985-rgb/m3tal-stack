# M3TAL Configuration

# Core settings
DOMAIN=example.com
TZ=America/Denver
PUID=1000
PGID=1000

# Security
DASHBOARD_SECRET=generate-a-random-secret-here
API_TOKEN=m3tal-secret-token

# API settings
STATE_DIR=/docker/state
GO_API_URL=http://m3tal-api:5050
GO_API_TOKEN=m3tal-secret-token

# Dashboard settings
DASHBOARD_PORT=8082
DASHBOARD_HOST=0.0.0.0
