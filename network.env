DASHBOARD_PORT=8082
DASHBOARD_EXPOSE_MODE=local
HTTP_PORT=8080
STATE_DIR=./state
LOG_LEVEL=info

# --- Auth ---
# Use a strong secret for session management (e.g., openssl rand -hex 32)
DASHBOARD_SECRET=change_me_immediately
# API Token for dashboard -> backend communication
API_TOKEN=change_me_api_token
# Initial admin password for the dashboard
ADMIN_PASSWORD=admin_pass

# --- Network ---
# The Docker network name (standard is 'm3tal')
NETWORK_NAME=m3tal
# Local IP of the host machine (for internal cross-service routing)
LOCAL_IP=127.0.0.1
# Root domain for service discovery (e.g., homelab.local)
DOMAIN=localhost

# --- VPN Credentials (Optional) ---
VPN_USER=user
VPN_PASSWORD=password

# --- Storage ---
# Base path for media and config (e.g., ./data or /mnt)
# NOTE: This path must exist on your host and be writable
BASE_STORAGE_PATH=./data

# Granular sub-paths (Relative to BASE_STORAGE_PATH by default)
MEDIA_PATH=./data/media
CONFIG_PATH=./data/config
DOWNLOADS_PATH=./data/downloads

# --- Host System Configuration ---
# User ID for file permissions (default is 1000 for first regular user)
PUID=1000
# Group ID for file permissions (default is 1000)
PGID=1000
# Timezone for container clocks (e.g., America/New_York, Europe/London)
TZ=America/Denver

# --- Traefik Configuration ---
# Ports must be free on the host (default: 80, 443, 8080)
TRAEFIK_WEB_PORT=80
TRAEFIK_WEBHTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080

# --- Advanced Options ---
# Set to true to enable debug logging
DEBUG_MODE=false
# Enable metrics collection
METRICS_ENABLED=true